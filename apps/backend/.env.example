# Database
DATABASE_URL=postgresql://user:password@localhost:5434/image_upload

# AWS S3（ローカル環境：S3呼び出しをモック・スキップ）
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=local-access-key
AWS_SECRET_ACCESS_KEY=local-secret-key
S3_BUCKET_NAME=image-upload-local
S3_PRESIGN_MODE=mock
S3_VALIDATION_MODE=skip

# Application
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10
