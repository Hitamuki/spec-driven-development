{
  "name": "@image-upload/backend",
  "version": "0.1.0",
  "description": "画像アップロード機能のバックエンドAPI",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --external @image-upload/domain --external @image-upload/db --external @image-upload/shared --external @image-upload/api --external @aws-sdk/client-s3 --external @aws-sdk/s3-request-presigner",
    "start": "bun dist/index.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "type-check": "tsc --noEmit",
    "doc": "typedoc --entryPoints src/index.ts --entryPoints src/routes/images.ts --entryPoints src/services/imageService.ts --out docs --skipErrorChecking"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:backend",
    "@aws-sdk/s3-request-presigner": "catalog:backend",
    "@hono/zod-validator": "catalog:backend",
    "@image-upload/domain": "workspace:*",
    "@image-upload/db": "workspace:*",
    "@image-upload/shared": "workspace:*",
    "@image-upload/api": "workspace:*",
    "hono": "catalog:backend",
    "pino": "catalog:backend",
    "zod": "catalog:default"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:default",
    "@types/node": "catalog:default",
    "typedoc": "catalog:default",
    "typescript": "catalog:default",
    "vitest": "catalog:default"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
