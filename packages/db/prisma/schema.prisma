generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Image {
  id          String   @id @default(uuid())
  fileName    String
  fileSize    Int
  contentType String
  s3Key       String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("images")
}
