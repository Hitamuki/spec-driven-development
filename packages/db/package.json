{
  "name": "@image-upload/db",
  "version": "0.1.0",
  "description": "DB繧｢繧ｯ繧ｻ繧ｹ螻､䰗啀risma縺ｨRepository",
  "main": "src/index.ts",
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "type-check": "tsc --noEmit",
    "doc": "typedoc --entryPoints src/index.ts --out docs --skipErrorChecking"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@image-upload/domain": "workspace:*",
    "pg": "^8.13.1",
    "zod": "catalog:default"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:default",
    "@types/node": "catalog:default",
    "prisma": "^7.5.0",
    "typedoc": "catalog:default",
    "typescript": "catalog:default",
    "vitest": "catalog:default"
  }
}
