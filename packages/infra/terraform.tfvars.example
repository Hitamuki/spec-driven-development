# AWS Configuration
aws_region   = "ap-northeast-1"
environment  = "production"
project_name = "image-upload"
assume_role_arn = "arn:aws:iam::866645635048:role/Hitamuki"
assume_role_session_name = "local-actions"

# Lambda Artifact Configuration (zipをS3に配置)
lambda_artifact_bucket = "image-upload-deploy-artifacts"
lambda_artifact_key = "backend/main.zip"
# lambda_artifact_object_version = "<S3 object version>"
# lambda_source_code_hash = "<Base64 encoded SHA-256>"

# Bastion Configuration (optional)
key_name = "image-upload-bastion"
bastion_instance_desired_state = "stopped"

# Database Configuration
db_name     = "imageupload"
db_username = "hitamuki"
db_password = "CHANGE_THIS_SECURE_PASSWORD"

# CORS Configuration
# CloudFront デプロイ後、生成されたドメインを追加してください
allowed_origins = [
  "http://localhost:3000",
  "https://localhost:3000"
]

# Optional: Domain Name (if using custom domain)
# デプロイ後にCloudFrontで生成されるドメイン名を使用
# domain_name = "d123abc456.cloudfront.net"
