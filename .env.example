# Database（本番環境は「AWS Secrets Managerのimage-upload/db-credentialsを参照」）
DATABASE_URL=postgresql://user:password@localhost:5434/image_upload

# AWS S3
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=your-bucket-name
S3_PRESIGN_MODE=aws
# ローカル環境ではskip / 本番環境ではstrict
S3_VALIDATION_MODE=skip

# Frontend
# ローカル環境ではtrue
VITE_SKIP_S3_UPLOAD=true

# Application
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10
